# ---------------------------------------------------------------------------
# Bind-mount cache directories (gitignored, observable — survive container rebuilds)
# The directory itself is tracked (so Docker can mount it); its contents are not.
# ---------------------------------------------------------------------------
.devcontainer/cache/*
!.devcontainer/cache/.gitkeep

# ---------------------------------------------------------------------------
# Local configuration (generated by scripts/init.sh from env.sample)
# ---------------------------------------------------------------------------
.env

# ---------------------------------------------------------------------------
# Python environment and build artifacts
# ---------------------------------------------------------------------------
.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
dist/
build/
*.egg-info/
.eggs/

# ---------------------------------------------------------------------------
# uv
# ---------------------------------------------------------------------------
# uv.lock is committed (lockfile for reproducible installs).
# Do NOT gitignore uv.lock.

# ---------------------------------------------------------------------------
# Type checker / linter caches
# ---------------------------------------------------------------------------
.ruff_cache/
.mypy_cache/
.ty_cache/

# ---------------------------------------------------------------------------
# pytest
# ---------------------------------------------------------------------------
.pytest_cache/
htmlcov/
.coverage

# ---------------------------------------------------------------------------
# macOS
# ---------------------------------------------------------------------------
.DS_Store
