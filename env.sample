# env.sample — template for .env
# Copy to .env (or run: bash scripts/init.sh) and adjust as needed.
# All variables are optional; code defaults point at the devcontainer bind-mount paths.
# Prefix: RLM_

# ---------------------------------------------------------------------------
# Ripgrep fixture
# ---------------------------------------------------------------------------

# Absolute path to the pinned ripgrep source clone (bind mount).
RLM_RIPGREP_SRC=/workspaces/ripgrep

# ---------------------------------------------------------------------------
# Rust / cargo caches
# ---------------------------------------------------------------------------

# Cargo build output directory for ripgrep compilation.
RLM_CARGO_TARGET_DIR=/workspaces/cargo-target

# CARGO_HOME bind mount (registry + git caches).
RLM_CARGO_HOME=/workspaces/cargo-home

# rust-analyzer targetDir (relocates RA's own cargo-check output).
RLM_RUST_ANALYZER_TARGET_DIR=/workspaces/cargo-target/rust-analyzer

# Path to the rust-analyzer binary inside the container.
# Confirm with: rustup which rust-analyzer
RLM_RUST_ANALYZER_BIN=/usr/local/cargo/bin/rust-analyzer

# ---------------------------------------------------------------------------
# ChromaDB / doc RAG
# ---------------------------------------------------------------------------

# ChromaDB PersistentClient storage path (bind mount).
RLM_CHROMA_PATH=/workspaces/chroma

# ONNX embedding-model cache path (bind-mounted to ~/.cache/chroma in the container).
RLM_CHROMA_MODEL_CACHE=/home/vscode/.cache/chroma

# Glob patterns for markdown files to index (comma-separated).
# Default indexes all *.md in the ripgrep source repo.
RLM_DOC_GLOB_PATTERNS=**/*.md
