# env.sample — template for .env
# Copy to .env (or run: bash scripts/init.sh) and adjust as needed.
# All variables are optional; code defaults point at the devcontainer bind-mount paths.
# Prefix: RLM_

# ---------------------------------------------------------------------------
# Target Rust project
# ---------------------------------------------------------------------------

# Absolute path to the target Rust project: the workspace rust-analyzer opens
# and whose Markdown files are indexed for doc search. Repo-agnostic — point it
# at any Rust project (default = the bundled ripgrep sample in the devcontainer).
RLM_PROJECT_ROOT=/workspaces/ripgrep
# Deprecated alias (still honored, warns): RLM_RIPGREP_SRC=/workspaces/ripgrep

# ---------------------------------------------------------------------------
# Rust / cargo caches
# ---------------------------------------------------------------------------

# Path to the rust-analyzer binary inside the container.
# Confirm with: rustup which rust-analyzer
RLM_RUST_ANALYZER_BIN=/usr/local/cargo/bin/rust-analyzer

# ---------------------------------------------------------------------------
# ChromaDB / doc RAG
# ---------------------------------------------------------------------------

# ChromaDB PersistentClient storage path (bind mount).
RLM_CHROMA_PATH=/workspaces/chroma

# ChromaDB collection name for the doc-RAG store.
RLM_DOC_COLLECTION=project_docs

# Glob patterns for markdown files to index (comma-separated).
# Default indexes all *.md in the target project.
RLM_DOC_GLOB_PATTERNS=**/*.md

# Comma-separated globs (relative to RLM_PROJECT_ROOT) to exclude from the doc index.
RLM_DOC_EXCLUDE_PATTERNS=**/CHANGELOG.md
